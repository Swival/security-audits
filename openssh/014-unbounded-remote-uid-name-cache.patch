+	(*count)++;
+	while (*count > IDNAME_CACHE_MAX) {
+		if ((old = TAILQ_FIRST(queue)) == NULL)
+			fatal_f("idname cache corrupt");
+		TAILQ_REMOVE(queue, old, qentry);
+		if (RB_REMOVE(idname_tree, tree, old) != old)
+			fatal_f("idname cache corrupt");
+		idname_free(old);
+		(*count)--;
+	}
 }
 
