-use {crate::component::bindings::fastly::compute::types, crate::session::Session};
+use {
+    crate::component::bindings::fastly::compute::types,
+    crate::session::Session,
+    std::{
+        collections::{HashMap, VecDeque},
+        sync::{Mutex, OnceLock},
+        time::{Duration, Instant},
+    },
+};
+
+#[derive(Default)]
+struct ErlState {
+    rate_counters: HashMap<(String, String), VecDeque<(Instant, u32)>>,
+    penalty_boxes: HashMap<(String, String), Instant>,
+}
+
+fn erl_state() -> &'static Mutex<ErlState> {
+    static ERL_STATE: OnceLock<Mutex<ErlState>> = OnceLock::new();
+    ERL_STATE.get_or_init(|| Mutex::new(ErlState::default()))
+}
 
 #[allow(clippy::too_many_arguments)]
 pub(crate) fn check_rate(
     _session: &mut Session,
-    _rc: &str,
-    _entry: String,
-    _delta: u32,
-    _window: u32,
-    _limit: u32,
-    _pb: &str,
-    _ttl: u32,
+    rc: &str,
+    entry: String,
+    delta: u32,
+    window: u32,
+    limit: u32,
+    pb: &str,
+    ttl: u32,
 ) -> Result<bool, types::Error> {
+    let now = Instant::now();
+    let penalty_key = (pb.to_owned(), entry.clone());
+    let mut state = erl_state().lock().unwrap();
+
+    state.penalty_boxes.retain(|_, expires_at| *expires_at > now);
+    if state.penalty_boxes.contains_key(&penalty_key) {
+        return Ok(true);
+    }
+
+    let counter = state
+        .rate_counters
+        .entry((rc.to_owned(), entry))
+        .or_default();
+    counter.push_back((now, delta));
+
+    let window_span = Duration::from_secs(u64::from(window));
+    let cutoff = now.checked_sub(window_span).unwrap_or(now);
+    while matches!(counter.front(), Some((seen_at, _)) if *seen_at < cutoff) {
+        counter.pop_front();
+    }
+
+    let used = counter.iter().fold(0u32, |total, (_, value)| {
+        total.saturating_add(*value)
+    });
+    let threshold = limit.saturating_mul(window);
+    if used > threshold {
+        state
+            .penalty_boxes
+            .insert(penalty_key, now + Duration::from_secs(u64::from(ttl)));
+        return Ok(true);
+    }
+
     Ok(false)
 }
