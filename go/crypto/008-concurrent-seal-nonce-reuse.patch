+	s.seqNumMu.Lock()
+	nonce := s.nextNonce()
 	s.seqNum++
+	s.seqNumMu.Unlock()
+	ciphertext := s.aead.Seal(nil, nonce, plaintext, aad)
 	return ciphertext, nil
 }
