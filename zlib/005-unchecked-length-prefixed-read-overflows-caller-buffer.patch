- * Read length of string + the string with the '>' operator.
+ * Read length of string + the string into a caller-provided buffer.
+ * Returns 0 if the encoded length does not fit, after skipping the input.
  */
-inline izstream& operator>(izstream& zs, char* x) {
+inline char* read_string(izstream& zs, char* x, size_t size) {
     zstringlen len(zs);
+    if (size == 0 || len.value() >= size) {
+        if (size != 0) x[0] = '\0';
+        ::gzseek(zs.fp(), (z_off_t) len.value(), SEEK_CUR);
+        return 0;
+    }
     ::gzread(zs.fp(), x, len.value());
     x[len.value()] = '\0';
+    return x;
+}
+
+template <int N>
+inline izstream& operator>(izstream& zs, char (&x)[N]) {
+    read_string(zs, x, N);
     return zs;
 }
 
