+/* write bytes to out, bailing on error */
+local void writen(const void *buf, unsigned len, FILE *out)
+{
+    if (fwrite(buf, 1, len, out) != len)
+        bail("write error on ", "stdout");
+}
+
+/* write one byte to out, bailing on error */
+local void put1(int val, FILE *out)
+{
+    if (putc(val, out) == EOF)
+        bail("write error on ", "stdout");
+}
+
 /* write a four-byte little-endian unsigned integer to out */
 local void put4(unsigned long val, FILE *out)
 {
-    putc(val & 0xff, out);
-    putc((val >> 8) & 0xff, out);
-    putc((val >> 16) & 0xff, out);
-    putc((val >> 24) & 0xff, out);
+    put1(val & 0xff, out);
+    put1((val >> 8) & 0xff, out);
+    put1((val >> 16) & 0xff, out);
+    put1((val >> 24) & 0xff, out);
 }
 
 /* Load up zlib stream from buffered input, bail if end of file */
