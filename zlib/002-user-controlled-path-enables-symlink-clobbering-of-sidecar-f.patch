--- a/examples/gzlog.c
+++ b/examples/gzlog.c
@@ -454,6 +454,34 @@ local int log_mark(struct log *log, int op)
     return ret;
 }
 
+/* Open an auxiliary file for rewrite without following symlinks. */
+local int log_side_open(struct log *log)
+{
+    int fd, flags;
+    struct stat st;
+
+    flags = O_WRONLY;
+#ifdef O_NOFOLLOW
+    flags |= O_NOFOLLOW;
+#endif
+    fd = open(log->path, flags, 0);
+    if (fd >= 0) {
+        if (fstat(fd, &st) || !S_ISREG(st.st_mode) || ftruncate(fd, 0) ||
+                lseek(fd, 0, SEEK_SET) < 0) {
+            close(fd);
+            return -1;
+        }
+        return fd;
+    }
+    if (errno != ENOENT)
+        return -1;
+    flags = O_WRONLY | O_CREAT | O_EXCL;
+#ifdef O_NOFOLLOW
+    flags |= O_NOFOLLOW;
+#endif
+    return open(log->path, flags, 0644);
+}
+
 /* Rewrite the last block header bits and subsequent zero bits to get to a byte
