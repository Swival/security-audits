+static int contains_relative_path_component(const char *path) {
+  const char *segment = path;
+
+  while (1)
+  {
+    if ((*path == '\\') || (*path == '/') || (*path == '\0'))
+    {
+      if ((path - segment == 2) && (segment[0] == '.') && (segment[1] == '.'))
+        return 1;
+      if (*path == '\0')
+        break;
+      segment = path + 1;
+    }
+    path++;
+  }
+
+  return 0;
+}
