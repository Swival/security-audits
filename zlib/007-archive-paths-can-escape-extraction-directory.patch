+static int has_dotdot_segment(const char *path) {
+    const char* segment = path;
+
+    while (*segment != '\0')
+    {
+        while (*segment == '/' || *segment == '\\')
+            segment++;
+
+        if (segment[0] == '.' && segment[1] == '.' &&
+            (segment[2] == '\0' || segment[2] == '/' || segment[2] == '\\'))
+            return 1;
+
+        while (*segment != '\0' && *segment != '/' && *segment != '\\')
+            segment++;
+    }
+
+    return 0;
+}
