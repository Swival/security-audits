+static void append_json_escaped(h2o_mem_pool_t *pool, h2o_iovec_vector_t *chunks, const char *src, size_t len)
+{
+    static const char hex[] = "0123456789abcdef";
+    h2o_iovec_t v;
+    char *dst;
+    const unsigned char *s = (const unsigned char *)src, *end = s + len;
+
+    v.base = h2o_mem_alloc_pool(pool, char, len * 6 + 1);
+    dst = v.base;
+
+    for (; s != end; ++s) {
+        if (' ' <= *s && *s < 0x7f) {
+            if (*s == '"' || *s == '\\')
+                *dst++ = '\\';
+            *dst++ = *s;
+        } else {
+            *dst++ = '\\';
+            *dst++ = 'u';
+            *dst++ = '0';
+            *dst++ = '0';
+            *dst++ = hex[(*s >> 4) & 0xf];
+            *dst++ = hex[*s & 0xf];
+        }
+    }
+    *dst = '\0';
+    v.len = dst - v.base;
+
+    h2o_vector_reserve(pool, chunks, chunks->size + 1);
+    chunks->entries[chunks->size++] = v;
+}
