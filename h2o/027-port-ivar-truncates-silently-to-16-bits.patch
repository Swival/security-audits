diff --git a/lib/handler/mruby/redis.c b/lib/handler/mruby/redis.c
index e3ee0fa55..3248d6cc9 100644
--- a/lib/handler/mruby/redis.c
+++ b/lib/handler/mruby/redis.c
@@ -142,7 +142,15 @@ static mrb_value connect_method(mrb_state *mrb, mrb_value self)
     mrb_value _host = mrb_iv_get(mrb, self, mrb_intern_lit(mrb, "@host"));
     mrb_value _port = mrb_iv_get(mrb, self, mrb_intern_lit(mrb, "@port"));
     const char *host = mrb_string_value_cstr(mrb, &_host);
