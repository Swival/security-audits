-use std::ops::Range;
+use std::{
+    ops::Range,
+    path::{Component, Path},
+};
 
 use super::*;
 
+fn validate_replayed_path(path: &str) -> Result<(), WasiRuntimeError> {
+    let invalid = Path::new(path)
+        .components()
+        .any(|component| matches!(component, Component::ParentDir | Component::RootDir | Component::Prefix(_)));
+    if invalid {
+        return Err(anyhow_err_to_runtime_err(anyhow::format_err!(
+            "journal restore error: invalid replay path ({path})"
+        )));
+    }
+    Ok(())
+}
