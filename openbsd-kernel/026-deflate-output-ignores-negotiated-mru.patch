diff --git a/net/ppp-deflate.c b/net/ppp-deflate.c
index 7f2b332..a493416 100644
--- a/net/ppp-deflate.c
+++ b/net/ppp-deflate.c
@@ -565,6 +565,10 @@ z_decompress(void *arg, struct mbuf *mi, struct mbuf **mop)
