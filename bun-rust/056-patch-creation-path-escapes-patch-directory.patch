+fn is_safe_patch_path(path: &[u8]) -> bool {
+    !path.is_empty()
+        && !paths::is_absolute_loose(path)
+        && !path
+            .split(|&c| c == b'/' || c == b'\\')
+            .any(|part| part == b"..")
