+static bool validJsonpCallback(const QByteArray &in) {
+    if (in.isEmpty())
+        return false;
+
+    bool expectStart = true;
+    for (int n = 0; n < in.size(); ++n) {
+        char c = in[n];
+
+        if (expectStart) {
+            if (!((c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z') || c == '_' || c == '$'))
+                return false;
+
+            expectStart = false;
+        } else if (c == '.') {
+            expectStart = true;
+        } else if (!((c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z') ||
+                     (c >= '0' && c <= '9') || c == '_' || c == '$'))
+            return false;
+    }
+
+    return !expectStart;
+}
