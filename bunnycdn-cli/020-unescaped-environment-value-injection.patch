+function serializeEnvVariable(variable: EdgeScriptVariable): string {
+  const name = variable.Name ?? "";
+  if (/[\r\n]/.test(name)) {
+    throw new UserError(
+      `Invalid environment variable name: ${JSON.stringify(name)}`,
+    );
+  }
+
+  const value = (variable.DefaultValue ?? "")
+    .replace(/\\/g, "\\\\")
+    .replace(/"/g, '\\"')
+    .replace(/\n/g, "\\n")
+    .replace(/\r/g, "\\r");
+
+  return `${name}="${value}"`;
+}
